//! FileType Registry — AUTO-GENERATED by ggen lsp-max pack
//! Source: lsp-max.toml server declarations
//! Edit lsp-max.toml, run `ggen sync` — never edit this file directly

use std::collections::HashMap;

/// Supported file extensions mapped to LSP server IDs
pub const SUPPORTED_FILE_TYPES: &[(&str, &str)] = &[

    ("**/.claude/settings*.json", "claude-config-json"),

];

/// Build a HashMap of extension -> server_id for runtime lookup
pub fn extension_to_server() -> HashMap<String, String> {
    SUPPORTED_FILE_TYPES
        .iter()
        .map(|(ext, id)| (ext.to_string(), id.to_string()))
        .collect()
}

/// Check if a given extension is supported by any LSP server
pub fn is_supported_extension(extension: &str) -> bool {
    SUPPORTED_FILE_TYPES.iter().any(|(ext, _)| ext == &extension)
}

/// Get the primary LSP server ID for a file extension
pub fn get_server_for_extension(extension: &str) -> Option<&'static str> {
    SUPPORTED_FILE_TYPES
        .iter()
        .find(|(ext, _)| ext == &extension)
        .map(|(_, id)| *id)
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_all_extensions_supported() {
        assert!(!SUPPORTED_FILE_TYPES.is_empty(), "at least one file type must be supported");
    }

    #[test]
    fn test_extension_lookup() {

        assert_eq!(get_server_for_extension("**/.claude/settings*.json"), Some("claude-config-json"));

    }

    #[test]
    fn test_unsupported_extension() {
        assert!(get_server_for_extension(".unknown").is_none());
    }

    #[test]
    fn test_hashmap_build() {
        let map = extension_to_server();
        assert_eq!(map.len(), SUPPORTED_FILE_TYPES.len());

        assert_eq!(map.get("**/.claude/settings*.json").map(|s| s.as_str()), Some("claude-config-json"));

    }
}