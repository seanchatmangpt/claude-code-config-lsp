PREFIX ccc: <https://claude-code-config-lsp.rs/ontology/>

SELECT ?constraint_type ?antecedent ?consequent
WHERE {
    ?constraint_id a ccc:DeclareConstraint ;
        ccc:constraintType ?constraint_type ;
        ccc:constraintA ?antecedent ;
        ccc:constraintB ?consequent .
}
ORDER BY ?constraint_type ?antecedent
