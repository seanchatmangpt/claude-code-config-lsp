PREFIX ccc: <https://claude-code-config-lsp.rs/ontology/>

SELECT ?constraint_type ?activity_a ?activity_b
WHERE {
    ?constraint_id a ccc:DeclareConstraint ;
        ccc:constraintType ?constraint_type ;
        ccc:constraintA ?activity_a .

    OPTIONAL { ?constraint_id ccc:constraintB ?activity_b . }
}
ORDER BY ?constraint_type ?activity_a
