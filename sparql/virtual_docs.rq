SELECT ?virtual_doc_uri ?virtual_doc_scheme ?doc_type ?doc_title ?server_name ?include_diagnostics WHERE {
    BIND("claude-config://health" AS ?virtual_doc_uri)
    BIND("claude-config" AS ?virtual_doc_scheme)
    BIND("health" AS ?doc_type)
    BIND("Claude Code Config Health Report" AS ?doc_title)
    BIND("ClaudeCodeConfig" AS ?server_name)
    BIND("true" AS ?include_diagnostics)
}
