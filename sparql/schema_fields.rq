PREFIX ccc: <https://claude-code-config-lsp.rs/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?server_name ?version ?class_name ?field_name ?field_type ?optional ?law_status ?stability WHERE {
    ?field_id a ccc:SchemaField ;
        ccc:fieldName ?field_name ;
        ccc:fieldType ?field_type ;
        ccc:fieldRequired ?required ;
        ccc:fieldSurface ?surface_id .
    ?surface_id rdfs:label ?class_name .
    BIND("ClaudeCodeConfig" AS ?server_name)
    BIND("26.6.24" AS ?version)
    BIND(IF(?required = "true"^^xsd:boolean, "false", "true") AS ?optional)
    BIND("CANDIDATE" AS ?law_status)
    BIND("stable" AS ?stability)
}
ORDER BY ?class_name ?field_name
