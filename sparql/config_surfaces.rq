PREFIX ccc: <https://claude-code-config-lsp.rs/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?analyzer_module ?analyzer_module_pascal ?law_status WHERE {
    ?surface a ccc:ConfigSurface ;
        ccc:analyzerModule ?analyzer_module ;
        ccc:analyzerModulePascal ?analyzer_module_pascal .
    BIND("CANDIDATE" AS ?law_status)
}
ORDER BY ?analyzer_module
